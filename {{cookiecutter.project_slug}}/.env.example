# Django settings
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_DATABASE_URL=postgres://postgres:debug@db:5432/postgres
DJANGO_DEFAULT_DOMAIN={{ cookiecutter.domain_name }}
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC
DJANGO_LANGUAGE_CODE=en

# Database connection pool
# DJANGO_DB_POOL_MIN_SIZE=1
# DJANGO_DB_POOL_MAX_SIZE=10
# DJANGO_DB_POOL_TIMEOUT=10

# CSRF / CORS (comma-separated, in addition to DJANGO_DEFAULT_DOMAIN)
# DJANGO_CSRF_TRUSTED_ORIGINS=
# DJANGO_CORS_ALLOWED_ORIGINS=

# Production security
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=True

# Granian server
# GRANIAN_HOST=0.0.0.0
# GRANIAN_PORT=8000
# GRANIAN_WORKERS=1
# GRANIAN_BLOCKING_THREADS=1

# PostgreSQL (used by compose)
POSTGRES_PASSWORD=debug

# Caddy (production)
# CADDY_DOMAIN=example.com
